# Copy to .env and fill in.
OPENAI_API_KEY=sk-...
# Model used by all agents (any OpenAI chat model with JSON-schema support)
ECHOLENS_MODEL=gpt-4o-mini
# SQLite for dev; swap for a Postgres URL later (e.g. Supabase pooler)
ECHOLENS_DB_URL=sqlite:///echolens.db

# Deployment mode: dev (auth OFF) | staging | production (auth required)
ECHOLENS_ENV=dev

# ── v1.0 collectors (all optional) ──────────────────────────────────────
# Play Store needs no credentials. GitHub is optional (raises rate limits).
# Reddit was removed as a live source: Reddit ended free API access in 2026.
GITHUB_TOKEN=
COLLECTOR_INTERVAL_HOURS=6

# ── v1.0 auth ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-prod
JWT_EXPIRE_MINUTES=1440

# ── v1.0 semantic search ────────────────────────────────────────────────
# hash (zero-dep, default) | sentence-transformers (pip install '.[embeddings]')
EMBEDDING_BACKEND=hash
EMBEDDING_DIM=256

# Logging
ECHOLENS_LOG_JSON=1
ECHOLENS_LOG_LEVEL=INFO
