# Copy to .env and fill in.
OPENAI_API_KEY=sk-...
# Model used by all agents (any OpenAI chat model with JSON-schema support)
ECHOLENS_MODEL=gpt-4o-mini
# SQLite for dev; swap for a Postgres URL later (e.g. Supabase pooler)
ECHOLENS_DB_URL=sqlite:///echolens.db

# Deployment mode: dev (auth OFF) | staging | production (auth required)
ECHOLENS_ENV=dev

# ── v1.0 collectors (all optional) ──────────────────────────────────────
# Play Store needs no credentials. GitHub is optional (raises rate limits).
# Reddit was removed as a live source: Reddit ended free API access in 2026.
GITHUB_TOKEN=
COLLECTOR_INTERVAL_HOURS=6

# ── v1.0 auth ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-prod
JWT_EXPIRE_MINUTES=1440
# CORS: your frontend origin(s), comma-separated (required in production)
CORS_ORIGINS=

# Free-tier bootstrap (no shell needed): if the DB has no users on startup and
# these are set, the backend creates the first admin automatically.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
# Seed the synthetic Lumo demo data on first boot if the corpus is empty.
SEED_ON_START=false

# ── v1.0 semantic search ────────────────────────────────────────────────
# hash (zero-dep, default) | sentence-transformers (pip install '.[embeddings]')
EMBEDDING_BACKEND=hash
EMBEDDING_DIM=256

# ── v4.0 delivery & actionability ───────────────────────────────────────
# Public URL of the frontend, used for deep links in Slack/email/tickets.
APP_BASE_URL=
ALERTS_ENABLED=true
# Findings at or above this severity (0..1) ping instantly; below → daily digest.
ALERT_INSTANT_MIN_SEVERITY=0.5
# Slack incoming-webhook URL for finding alerts + digest (optional).
SLACK_WEBHOOK_URL=
# Shared secret that guards the reply-to-act endpoint (Slack "approve"/"challenge").
SLACK_ACTION_TOKEN=
# On a Slack approve, also open a GitHub issue automatically.
AUTO_CREATE_ISSUE_ON_APPROVE=false
# Repo (owner/name) for issue creation when a product has no connected GitHub source.
GITHUB_DEFAULT_REPO=
# Secret to verify GitHub issue-webhook signatures (v6.0 fix verification). Set the
# same value in the repo's webhook config → EchoLens starts a fix-watch on close.
GITHUB_WEBHOOK_SECRET=
# Email delivery (optional; leave SMTP_HOST empty to skip email).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Logging
ECHOLENS_LOG_JSON=1
ECHOLENS_LOG_LEVEL=INFO
